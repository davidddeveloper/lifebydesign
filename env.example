# ─────────────────────────────────────────────
# Startup Bodyshop — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Anthropic (Claude) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Resend (email) ────────────────────────────
RESEND_API_KEY=re_...

# ── Sanity CMS ────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_BASE_URL=https://yourdomain.com/studio/
NEXT_PUBLIC_SANITY_PREVIEW_SECRET=your_preview_secret
SANITY_API_READ_TOKEN=your_sanity_read_token
SANITY_API_TOKEN=your_sanity_write_token
SANITY_PREVIEW_SECRET=your_preview_secret

# ── Monime (payments) ─────────────────────────
MONIME_SPACE_ID=spc-...
MONIME_ACCESS_TOKEN=mon_...
MONIME_API_URL=https://api.monime.io
MONIME_WEBHOOK_SECRET=your_monime_webhook_secret

# ── n8n Webhooks ──────────────────────────────
N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/process-audit
N8N_EMAIL_WEBHOOK_URL=https://your-n8n-instance/webhook/send-mail

# ── Site URLs ─────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=https://yourdomain.com

# ── Booking / Scheduling ──────────────────────
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-link
NEXT_PUBLIC_CAL_LINK=your-cal-username/30min

# ── Feature Flags ─────────────────────────────
# Set to "true" to enable the AI result assistant chat widget on the results page
NEXT_PUBLIC_RESULT_ASSISTANT_ENABLED=false
# Set to "true" to show the Beta tag and feedback widget on the audit form
NEXT_PUBLIC_SHOW_BETA_TAG=false

# ── PayloadCMS (if used) ──────────────────────
DATABASE_URI=postgresql://user:password@host:5432/dbname
PAYLOAD_SECRET=your_payload_secret
